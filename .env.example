# AutoInvest 환경변수 템플릿
# 이 파일을 복사해 .env 파일을 만들고, 실제 키를 입력하세요.
#
#   cp .env.example .env
#
# .env 파일은 .gitignore에 의해 Git에 추적되지 않습니다.
# 절대 .env 파일을 GitHub에 커밋하지 마세요!

# ------------------------------------------------------------------
# Gemini API 키 (AI 시황 분석 모듈에 사용)
# 발급: https://aistudio.google.com/app/apikey
# ------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
